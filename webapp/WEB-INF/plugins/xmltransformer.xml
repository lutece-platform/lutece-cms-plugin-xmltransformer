<?xml version="1.0" encoding="UTF-8"?><plug-in>
    <name>xmltransformer</name>
    <class>fr.paris.lutece.portal.service.plugin.PluginDefaultImplementation</class>
    <version>1.0.0-beta-01</version>
    <documentation/>
    <installation/>
    <changes/>
    <user-guide/>
    <description>xmltransformer.plugin.description</description>
    <provider>xmltransformer.plugin.provider</provider>
    <provider-url>https://fr.lutece.paris.fr</provider-url>
    <icon-url>images/admin/skin/feature_default_icon.png</icon-url>
    <copyright>Copyright (c) Ville de Paris</copyright>
    <db-pool-required>1</db-pool-required>
    
    <core-version-dependency>
        <min-core-version>4.1.0</min-core-version>
        <max-core-version/>
    </core-version-dependency>

    <!-- Admin features parameters -->
    <admin-features>
        <admin-feature>
            <feature-id>CORE_STYLES_MANAGEMENT</feature-id>
            <feature-title>xmltransformer.adminFeature.styles_management.name</feature-title>
            <feature-description>xmltransformer.adminFeature.styles_management.description</feature-description>
            <feature-level>1</feature-level>
            <feature-url>jsp/admin/style/ManageStyles.jsp</feature-url>
            <feature-group>STYLE</feature-group>
            <feature-icon-url>ti ti-brush</feature-icon-url>
        </admin-feature>
        <admin-feature>
            <feature-id>CORE_STYLESHEET_MANAGEMENT</feature-id>
            <feature-title>xmltransformer.adminFeature.stylesheet_management.name</feature-title>
            <feature-description>xmltransformer.adminFeature.stylesheet_management.description</feature-description>
            <feature-level>1</feature-level>
            <feature-url>jsp/admin/style/ManageStyleSheets.jsp</feature-url>
            <feature-group>STYLE</feature-group>
            <feature-icon-url>ti ti-file-code</feature-icon-url>
        </admin-feature>
    </admin-features>

	<!-- Servlets -->
    <servlets>
    	<servlet>
    		<servlet-name>StyleSheetServlet</servlet-name>
    		<servlet-class>fr.paris.lutece.portal.web.stylesheet.StyleSheetFileServlet</servlet-class>
    		<url-pattern>/servlet/plugins/xmltransformer/viewStyleSheetFile</url-pattern>
    	</servlet>
    </servlets>

</plug-in>