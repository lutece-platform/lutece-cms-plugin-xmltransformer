<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd" >

	<!-- package portlet -->
	<bean id="portletStyleDAO" class="fr.paris.lutece.portal.business.portlet.PortletStyleXslDAO" />

	<!-- package style -->
	<bean id="styleDAO" class="fr.paris.lutece.portal.business.style.StyleDAO" />

    <!-- package stylesheet -->
    <bean id="styleSheetDAO" class="fr.paris.lutece.portal.business.stylesheet.StyleSheetDAO" />

	<bean id="portletContentService" class="fr.paris.lutece.portal.service.portlet.PortletContentXslService" autowire="constructor" />

	<bean id="xmlTransformerCacheManager" class="fr.paris.lutece.portal.service.html.XmlTransformerCacheManager" />

</beans>
